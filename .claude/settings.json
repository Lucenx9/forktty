{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "Bash(cargo *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Agent(*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:tauri.app)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git checkout *)",
      "Bash(rm *)",
      "Bash(cargo publish *)",
      "Bash(cargo tauri build *)"
    ],
    "deny": [
      "Read(.env)",
      "Bash(rm -rf /)*",
      "Bash(git push --force *)"
    ]
  },
  "plansDirectory": "./plans",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "([ -f src-tauri/Cargo.toml ] && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check 2>/dev/null || true) && ([ -f package.json ] && npx prettier --write --log-level silent src/ 2>/dev/null || true)"
          }
        ]
      }
    ]
  }
}
